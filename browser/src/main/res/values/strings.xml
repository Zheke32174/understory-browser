<?xml version="1.0" encoding="utf-8"?>
<!--
  Browser app strings. Suite-shared strings (cd_back, action_retry, …) live in
  common-security/res/values/strings.xml; only browser-specific copy is here.
  Naming mirrors the shared convention (S-2): cd_* a11y labels, action_*
  buttons, msg_* inline copy, err_* error-panel titles.

  Store-facing display name is "Understory Safe View" (design-v2 §Positioning).
  The package id (com.understory.browser) is unchanged — only the label.
-->
<resources>
    <string name="app_name">Safe View</string>
    <!-- Chooser-entry verb for the share/VIEW aliases (reads a verb, not the app name). -->
