    <!-- Empty / placeholder -->
    <string name="placeholder_main">Type an https:// URL above and tap Go.\n\nJS is off by default for every site — the JS toggle opts the current site in (persisted allowlist). Cookies: first-party only per toggle, third-party always blocked.\n\nCleared when you close the app, or tap Clear now. Switching apps does NOT clear it.\n\nSafe Browsing is on when the device\'s WebView provider supports it. Screenshots are blocked here; to capture a suspicious page, open it in your default browser.</string>

    <!-- Intake interstitial -->
    <string name="intake_heading">Open this link in the hardened viewer?</string>
    <string name="intake_sub">JavaScript will be OFF. No cookies, no downloads, no location, camera, or mic. The link opens here, not in your normal browser.</string>
